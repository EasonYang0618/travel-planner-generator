@startuml
actor User
participant Website
participant "Flask API" as API
participant APIFree
User -> Website: Submit preferences
activate Website
Website -> Website: validate input
alt valid
 Website -> API: POST /api/itinerary
 activate API
 API -> API: build schema
 API --> Website: Itinerary response
 deactivate API
 Website -> API: GET /api/image
 activate API
 API -> APIFree: GET /image
 activate APIFree
 APIFree --> API: Image data
 deactivate APIFree
 API --> Website: Image response
 Website -> Website: render readable fields
 Website --> User: Display itinerary and image
else invalid
 Website --> User: Show error
end
deactivate Website
@enduml