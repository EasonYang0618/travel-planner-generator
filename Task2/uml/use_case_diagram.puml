@startuml
left to right direction

actor Tourist
actor "Travel Agency Assistant" as Assistant

rectangle "Travel Planner Generator" {
  usecase "Enter preferences\n(destination, length, budget, interests)" as UC_Enter
  usecase "Generate itinerary" as UC_Generate
  usecase "View website" as UC_Website
  usecase "Request destination image" as UC_Image
  usecase "Access API\n(POST /api/itineraries)" as UC_API
}

Tourist -- UC_Website
Tourist -- UC_Enter
Tourist -- UC_Image

Assistant -- UC_Enter
Assistant -- UC_Generate
Assistant -- UC_API
Assistant -- UC_Image

UC_Generate ..> UC_Enter : <<include>>
UC_API ..> UC_Generate : <<include>>
UC_Website ..> UC_Enter : <<include>>
UC_Website ..> UC_Generate : <<include>>
@enduml